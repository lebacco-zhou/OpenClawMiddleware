{
  "Server": {
    "WebSocketPort": 8445,
    "HttpPort": 8080,
    "Host": "0.0.0.0",
    "MaxConnections": 100,
    "MaxMessageSizeBytes": 1048576
  },
  "Gateway": {
    "BaseUrl": "http://localhost:18789",
    "Token": "${GATEWAY_TOKEN}",
    "TimeoutSeconds": 30,
    "RetryCount": 3
  },
  "Security": {
    "RsaKeyPath": "/etc/openclaw/middleware/rsa-key.pem",
    "SessionTimeoutMinutes": 60,
    "MaxNonceAgeSeconds": 300,
    "RequireAuth": true
  },
  "Heartbeat": {
    "IntervalSeconds": 30,
    "TimeoutSeconds": 90,
    "MaxMissedHeartbeats": 3
  },
  "RateLimit": {
    "Enabled": true,
    "MaxMessagesPerMinute": 100,
    "BurstLimit": 20
  },
  "FileStorage": {
    "BasePath": "/var/www/openclaw-files/uploads",
    "TempPath": "/var/www/openclaw-files/temp",
    "MaxFileSizeBytes": 52428800,
    "ChunkSizeBytes": 102400,
    "FileUrlPrefix": "https://www.lebacco.cn:8444/files/",
    "CleanupTempIntervalMinutes": 60
  },
  "ClientTokens": {
    "TokenFilePath": "/etc/openclaw/middleware/client-tokens.json",
    "AllowDynamicRegistration": false,
    "TokenExpiryDays": 365
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "Serilog": {
      "MinimumLevel": "Information"
    }
  }
}
